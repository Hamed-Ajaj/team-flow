    "better-auth": "^1.4.13",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3",
    "zod": "^4.0.0"
  },
