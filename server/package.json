    "test:db:push": "DB_PORT=5433 DB_NAME=app_test pnpm db:push",
    "test:ci": "pnpm test:db:up && pnpm test:db:push && vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
